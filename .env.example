# Configurações do Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co   # URL do projeto no Supabase
SUPABASE_KEY=your_supabase_anon_key                     # Substitua pela chave pública anônima

# Configurações da Z-API
ZAPI_INSTANCE_ID=your_instance_id                       # Identificador único da sua instância
ZAPI_TOKEN=your_instance_token                          # Token de segurança da instância
ZAPI_CLIENT_TOKEN=your_client_token                     # Token do cliente para autenticação de requisições